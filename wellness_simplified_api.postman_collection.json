									"key": "password",
									"value": "P@ssword123!",
									"type": "text"
								},
								{
									"key": "confirm_password",
									"value": "P@ssword123!",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/users/register/provider/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"register",
								"provider",
								""
							]
						},
						"description": "Registers a new healthcare provider. Note that provider accounts start as unverified (`is_verified=False`) and cannot log in until approved in the admin panel."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access) {",
									"    pm.environment.set(\"access_token\", jsonData.access);",
									"}",
									"if (jsonData.refresh) {",
									"    pm.environment.set(\"refresh_token\", jsonData.refresh);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"janesmith@wellness.com\",\n    \"password\": \"P@ssword123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/users/login/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"login",
								""
							]
						},
						"description": "Logs in the user and returns simplejwt access and refresh tokens. For provider accounts, the user must be verified by an administrator, otherwise a 400 bad request validation error is returned."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/users/token/refresh/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"token",
								"refresh",
								""
							]
						},
						"description": "Uses a refresh token to obtain a fresh access token."
					},
					"response": []
				},
