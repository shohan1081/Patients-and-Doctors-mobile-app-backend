				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access) {",
									"    pm.environment.set(\"access_token\", jsonData.access);",
									"}",
									"if (jsonData.refresh) {",
									"    pm.environment.set(\"refresh_token\", jsonData.refresh);",
